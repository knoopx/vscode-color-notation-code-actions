{
	"name": "color-notation-code-actions",
	"displayName": "Color Notation Code Actions",
	"description": "Code Actions for transforming from one color notation to another",
	"version": "0.0.1",
	"publisher": "knoopx",
	"repository": "https://github.com/knoopx/vscode-color-notation-code-actions",
	"engines": {
		"vscode": "^1.51.0"
	},
	"categories": [
		"Other"
	],
	"main": "./out/main.js",
	"activationEvents": [
		"onStartupFinished"
	],
	"scripts": {
		"vscode:prepublish": "yarn run compile",
		"compile": "tsc -p ./",
		"lint": "eslint src --ext ts",
		"watch": "tsc -watch -p ./",
		"pretest": "yarn run compile && yarn run lint",
		"test": "node ./out/test/runTest.js"
	},
	"devDependencies": {
		"@types/node": "^12.11.7",
		"@types/vscode": "^1.51.0",
		"typescript": "^4.0.2"
	},
